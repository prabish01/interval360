# Public Cal.com booking link (e.g. "interval360" for cal.com/interval360).
# Not a secret — this is the public booking page slug used by the "Book a Call" CTAs.
NEXT_PUBLIC_CAL_LINK=interval360

# Supabase Postgres connection strings (Project Settings > Database > Connection string).
# DATABASE_URL: pooled connection (via PgBouncer, port 6543) — used at runtime.
# DIRECT_URL: direct/session connection (port 5432) — used for migrations.
DATABASE_URL=
DIRECT_URL=


# Resend API key — not wired up yet, used later to send newsletter campaigns
# to the emails collected in the Subscriber table.
RESEND_API_KEY=
