# Public Cal.com booking link (e.g. "interval360" for cal.com/interval360).
# Not a secret — this is the public booking page slug used by the "Book a Call" CTAs.
NEXT_PUBLIC_CAL_LINK=interval360

# Base URL of the Interval360 Node.js API (code/nodejs in ProjectSuez) used by
# the login and /buy signup forms. Not a secret — this is a browser-visible
# fetch target, same as the api.interval360.com clients use in production.
NEXT_PUBLIC_API_URL=http://localhost:9415/api

# The admin dashboard app (code/frontend-admin in ProjectSuez) — /admin/login
# hands off here after a successful password sign-in.
NEXT_PUBLIC_DASHBOARD_URL=http://localhost:3001

# The regular-user app (code/frontend-user in ProjectSuez, live at
# user.interval360.com) — /login hands off here after a successful email +
# OTP sign-in. This is a different app from the admin dashboard above.
NEXT_PUBLIC_USER_APP_URL=http://localhost:3002

# Supabase Postgres connection strings (Project Settings > Database > Connection string).
# DATABASE_URL: pooled connection (via PgBouncer, port 6543) — used at runtime.
# DIRECT_URL: direct/session connection (port 5432) — used for migrations.
DATABASE_URL=
DIRECT_URL=

# Resend API key — not wired up yet, used later to send newsletter campaigns
# to the emails collected in the Subscriber table.
RESEND_API_KEY=

# OpenAI API key used server-side by /api/demo-chat (the /demo page's live chatbot demo).
# Secret — never prefix with NEXT_PUBLIC_, never expose to the browser.
OPENAI_API_KEY=

# Model used for the /demo chatbot. Defaults to gpt-4o if unset.
OPENAI_MODEL=gpt-4o
