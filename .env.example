# Public Cal.com booking link (e.g. "interval360" for cal.com/interval360).
# Not a secret — this is the public booking page slug used by the "Book a Call" CTAs.
NEXT_PUBLIC_CAL_LINK=interval360

# OpenAI API key used server-side by /api/demo-chat (the /demo page's live chatbot demo).
# Secret — never prefix with NEXT_PUBLIC_, never expose to the browser.
OPENAI_API_KEY=

# Model used for the /demo chatbot. Defaults to gpt-4o if unset.
OPENAI_MODEL=gpt-4o
